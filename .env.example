DATABASE_URL=postgresql://postgres:CGhYEoROTtHYwJZGOOpnpAEUijEZdGFA@postgres.railway.internal:5432/railway
SESSION_SECRET=replace-with-a-long-random-secret
NODE_ENV=production

# Explicit user table mapping (recommended for your schema)
USER_TABLE=users
USER_ID_COLUMN=id
USER_USERNAME_COLUMN=username
USER_PASSWORD_COLUMN=pass_hash
USER_SALT_COLUMN=salt

# Hash mode used when creating/updating passwords
# Supported: sha256_salt_password, sha256_password_salt, sha256_salt_colon_password, sha256_password_colon_salt, sha256_password
USER_HASH_MODE=scrypt

# Base URL used inside password-reset emails
APP_BASE_URL=https://colabwebsite-production.up.railway.app

# SMTP settings for forgot-password email
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-user
SMTP_PASS=your-password
SMTP_FROM=ColabGames <no-reply@colabgames.com>
SMTP_IP_FAMILY=4
SMTP_CONNECTION_TIMEOUT_MS=6000
SMTP_GREETING_TIMEOUT_MS=6000
SMTP_SOCKET_TIMEOUT_MS=12000
FORGOT_SMTP_TIMEOUT_MS=8000
FORGOT_DB_TIMEOUT_MS=4500

# Email provider: smtp (default), resend, or auto (try SMTP then Resend fallback)
EMAIL_PROVIDER=smtp

# Resend API (recommended on Railway if SMTP times out)
RESEND_API_KEY=re_xxx
RESEND_FROM=ColabGames <onboarding@resend.dev>
RESEND_TIMEOUT_MS=8000
