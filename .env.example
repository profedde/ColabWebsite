DATABASE_URL=postgresql://postgres:CGhYEoROTtHYwJZGOOpnpAEUijEZdGFA@postgres.railway.internal:5432/railway
SESSION_SECRET=replace-with-a-long-random-secret
NODE_ENV=production
PGSSL=disable

# Explicit user table mapping (recommended for your schema)
USER_TABLE=users
USER_ID_COLUMN=id
USER_USERNAME_COLUMN=username
USER_PASSWORD_COLUMN=pass_hash
USER_SALT_COLUMN=salt
USER_EMAIL_COLUMN=email

# Hash mode used when creating/updating passwords
# Supported: sha256_salt_password, sha256_password_salt, sha256_salt_colon_password, sha256_password_colon_salt, sha256_password
USER_HASH_MODE=scrypt

# Base URL used inside password-reset emails
APP_BASE_URL=https://colabwebsite-production.up.railway.app

# Brevo API settings for forgot-password email
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
BREVO_FROM_NAME=ColabGames
BREVO_FROM_EMAIL=your-verified-sender@example.com
BREVO_TIMEOUT_MS=8000

FORGOT_EMAIL_TIMEOUT_MS=8000
FORGOT_DB_TIMEOUT_MS=4500
