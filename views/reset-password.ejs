<!doctype html>
<html lang="en" data-page="reset-password">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Reset Password | ColabGames</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Nunito:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/assets/colab-logo.png" />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <img src="/assets/colab-logo.png" alt="ColabGames logo" />
        <span>ColabGames</span>
      </a>
    </header>

    <main class="page-shell">
      <section class="card" style="max-width: 520px; margin: 0 auto">
        <p class="kicker">ACCOUNT SECURITY</p>
        <h1 style="font-size: clamp(1.8rem, 4vw, 2.4rem)">Reset Password</h1>

        <% if (flash) { %>
          <div class="flash-message flash-<%= flash.type %>" style="margin-top: 0.85rem">
            <%= flash.message %>
          </div>
        <% } %>

        <% if (tokenValid) { %>
          <form class="form-stack" method="post" action="/reset-password">
            <input type="hidden" name="token" value="<%= token %>" />
            <input
              class="auth-input"
              type="password"
              name="newPassword"
              minlength="8"
              placeholder="New password"
              required
            />
            <input
              class="auth-input"
              type="password"
              name="confirmNewPassword"
              minlength="8"
              placeholder="Confirm new password"
              required
            />
            <button class="button primary" type="submit">Set new password</button>
          </form>
        <% } else { %>
          <p class="lead compact">This reset link is invalid or expired. Request a new one from Login.</p>
          <div class="actions compact">
            <a class="button" href="/">Back to login</a>
          </div>
        <% } %>
      </section>
    </main>

    <footer class="site-footer">
      <p>&copy; <span id="year"></span> ColabGames</p>
      <div class="footer-links">
        <a href="/privacy-policy.html">Privacy</a>
        <a href="/terms-and-conditions.html">Terms</a>
        <a href="/support.html">Support</a>
        <a href="/delete-account.html">Delete Account</a>
      </div>
    </footer>

    <script>
      (function () {
        var year = document.getElementById("year");
        if (year) year.textContent = String(new Date().getFullYear());
      })();
    </script>
  </body>
</html>
