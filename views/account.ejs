<!doctype html>
<html lang="en" data-page="account">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>My Account | ColabGames</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Nunito:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/assets/colab-logo.png" />
    <link rel="stylesheet" href="/style.css" />
    <script defer src="/home-auth.js"></script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <img src="/assets/colab-logo.png" alt="ColabGames logo" />
        <span>ColabGames</span>
      </a>
      <nav id="site-nav" class="site-nav">
        <a href="/">Home</a>
        <a href="/chessguess.html">ChessGuess</a>
        <a href="/support.html">Support</a>
        <a class="active" href="/account">Account</a>
      </nav>
      <div class="header-actions">
        <button
          id="menu-toggle"
          class="menu-toggle"
          aria-expanded="false"
          aria-controls="site-nav"
          type="button"
        >
          Menu
        </button>
        <form action="/logout" method="post">
          <button class="auth-btn" type="submit">Log out</button>
        </form>
      </div>
    </header>

    <main class="page-shell">
      <section class="card hero hero-slim">
        <div>
          <p class="kicker">COLAB ACCOUNT</p>
          <h1>Welcome back, <%= user.username || "Player" %>.</h1>
          <p class="lead">Manage your GuessChess profile, credentials, and account requests.</p>
        </div>
        <div class="hero-art hero-art-small">
          <img src="/assets/chessguess-logo.png" alt="GuessChess icon" />
        </div>
      </section>

      <% if (flash) { %>
        <section class="flash-message flash-<%= flash.type %>"><%= flash.message %></section>
      <% } %>

      <section class="grid two-col">
        <article class="card">
          <h2>Profile</h2>
          <dl class="spec-list">
            <div>
              <dt>Username</dt>
              <dd><%= user.username || "N/A" %></dd>
            </div>
            <div>
              <dt>Email</dt>
              <dd><%= user.email || "N/A" %></dd>
            </div>
            <div>
              <dt>User ID</dt>
              <dd><%= user.id %></dd>
            </div>
          </dl>
        </article>

        <article class="card">
          <h2>Change Password</h2>
          <form action="/account/change-password" method="post" class="form-stack">
            <input
              class="auth-input"
              type="password"
              name="currentPassword"
              placeholder="Current password"
              required
            />
            <input
              class="auth-input"
              type="password"
              name="newPassword"
              minlength="8"
              placeholder="New password"
              required
            />
            <input
              class="auth-input"
              type="password"
              name="confirmNewPassword"
              minlength="8"
              placeholder="Confirm new password"
              required
            />
            <button class="button primary" type="submit">Update Password</button>
          </form>
        </article>
      </section>

      <section class="card">
        <h2>Delete Account Request</h2>
        <p class="lead compact">
          Request account deletion and the Colab team will process it as soon as possible.
        </p>
        <form action="/account/delete-request" method="post" class="form-stack">
          <textarea
            class="auth-input"
            name="reason"
            rows="4"
            placeholder="Reason (optional)"
          ></textarea>
          <button class="button danger" type="submit">Request Deletion</button>
        </form>
      </section>
    </main>

    <footer class="site-footer">
      <p>&copy; <span id="year"></span> ColabGames</p>
      <div class="footer-links">
        <a href="/privacy-policy.html">Privacy</a>
        <a href="/terms-and-conditions.html">Terms</a>
        <a href="/support.html">Support</a>
        <a href="/delete-account.html">Delete Account</a>
      </div>
    </footer>

  </body>
</html>

