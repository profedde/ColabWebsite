<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Account | Colab</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page page-account">
      <section class="hero account-hero">
        <div>
          <p class="eyebrow">COLAB ACCOUNT</p>
          <h1>GuessChess</h1>
          <p class="subtitle">Manage your account settings.</p>
        </div>
        <form action="/logout" method="post">
          <button type="submit" class="button-secondary">Log Out</button>
        </form>
      </section>

      <% if (flash) { %>
        <section class="flash flash-<%= flash.type %>"><%= flash.message %></section>
      <% } %>

      <section class="cards three-col">
        <article class="card">
          <h2>Profile</h2>
          <div class="profile-grid">
            <p><span>Email:</span> <%= user.email || "N/A" %></p>
            <p><span>Username:</span> <%= user.username || "N/A" %></p>
            <p><span>User ID:</span> <%= user.id %></p>
          </div>
        </article>

        <article class="card">
          <h2>Change Password</h2>
          <form action="/account/change-password" method="post" class="form">
            <label>
              Current Password
              <input type="password" name="currentPassword" required />
            </label>
            <label>
              New Password
              <input type="password" name="newPassword" minlength="8" required />
            </label>
            <label>
              Confirm New Password
              <input type="password" name="confirmNewPassword" minlength="8" required />
            </label>
            <button type="submit">Update Password</button>
          </form>
        </article>

        <article class="card danger">
          <h2>Delete Account Request</h2>
          <p class="muted">
            Submit your request and the team will process account deletion.
          </p>
          <form action="/account/delete-request" method="post" class="form">
            <label>
              Reason (optional)
              <textarea name="reason" rows="4" placeholder="Reason"></textarea>
            </label>
            <button type="submit" class="button-danger">Request Deletion</button>
          </form>
        </article>
      </section>

      <footer class="legal-links">
        <a href="/privacy-policy.html">Privacy Policy</a>
        <a href="/terms-and-conditions.html">Terms & Conditions</a>
        <a href="/delete-account.html">Delete Account</a>
      </footer>
    </main>
  </body>
</html>
