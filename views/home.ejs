<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Colab | GuessChess</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page page-home">
      <section class="hero">
        <p class="eyebrow">INDIE GAME STUDIO</p>
        <h1>Colab</h1>
        <p class="subtitle">
          First title: <strong>GuessChess</strong>. Log in to your account or create one to manage
          your profile.
        </p>

        <div class="store-buttons">
          <a class="store-button" href="#" aria-disabled="true">
            <span class="store-top">Get it on</span>
            <span class="store-main">Google Play</span>
          </a>
          <a class="store-button" href="#" aria-disabled="true">
            <span class="store-top">Download on the</span>
            <span class="store-main">App Store</span>
          </a>
        </div>
      </section>

      <% if (flash) { %>
        <section class="flash flash-<%= flash.type %>"><%= flash.message %></section>
      <% } %>

      <section class="cards two-col">
        <article class="card">
          <h2>Log In</h2>
          <form action="/login" method="post" class="form">
            <label>
              Email or Username
              <input type="text" name="identifier" required />
            </label>
            <label>
              Password
              <input type="password" name="password" required />
            </label>
            <button type="submit">Log In</button>
          </form>
        </article>

        <article class="card">
          <h2>Register</h2>
          <form action="/register" method="post" class="form">
            <label>
              Email
              <input type="email" name="email" />
            </label>
            <label>
              Username
              <input type="text" name="username" />
            </label>
            <label>
              Password
              <input type="password" name="password" minlength="8" required />
            </label>
            <label>
              Confirm Password
              <input type="password" name="confirmPassword" minlength="8" required />
            </label>
            <button type="submit">Create Account</button>
          </form>
        </article>
      </section>

      <footer class="legal-links">
        <a href="/privacy-policy.html">Privacy Policy</a>
        <a href="/terms-and-conditions.html">Terms & Conditions</a>
        <a href="/delete-account.html">Delete Account</a>
      </footer>
    </main>
  </body>
</html>
