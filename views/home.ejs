<!doctype html>
<html lang="en" data-page="home">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Official ColabGames website with ChessGuess page, support, and legal information."
    />
    <title>ColabGames | ChessGuess</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Nunito:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/assets/colab-logo.png" />
    <link rel="stylesheet" href="/style.css" />
    <link rel="stylesheet" href="/home-auth.css" />
    <script defer src="/home-auth.js"></script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <img src="/assets/colab-logo.png" alt="ColabGames logo" />
        <span>ColabGames</span>
      </a>

      <nav id="site-nav" class="site-nav">
        <a class="active" href="/">Home</a>
        <a href="/chessguess.html">ChessGuess</a>
        <a href="/support.html">Support</a>
      </nav>

      <div class="header-actions">
        <button id="lang-toggle" class="lang-toggle" type="button">EN</button>
        <button id="open-auth-btn" class="auth-btn" type="button">Login</button>
        <button
          id="menu-toggle"
          class="menu-toggle"
          aria-expanded="false"
          aria-controls="site-nav"
          type="button"
        >
          Menu
        </button>
      </div>
    </header>

    <main class="page-shell">
      <section class="hero card">
        <div>
          <p class="kicker">INDIE GAME STUDIO</p>
          <h1>ColabGames builds games around fast decisions.</h1>
          <p class="lead">
            Current focus: ChessGuess, a hidden-information strategy game with bot mode, custom
            rooms, and competitive online multiplayer.
          </p>
          <div class="actions">
            <a class="button primary" href="#">Play ChessGuess Web</a>
            <a class="button" href="/chessguess.html">Game page</a>
          </div>
          <div class="store-row">
            <a class="store-badge-link" href="#" aria-disabled="true">
              <img
                class="store-badge-img"
                src="/assets/Google_Play_Store_badge_EN.svg"
                alt="Get it on Google Play"
              />
            </a>
            <a class="store-badge-link" href="#" aria-disabled="true">
              <img
                class="store-badge-img store-badge-apple"
                src="/assets/Download_on_the_App_Store_Badge.svg"
                alt="Download on the App Store"
              />
            </a>
          </div>
        </div>
        <div class="hero-art">
          <img src="/assets/chessguess-logo.png" alt="ChessGuess logo" />
        </div>
      </section>

      <section class="card">
        <h2>Official Links</h2>
        <ul class="link-list">
          <li><a href="/privacy-policy.html">Privacy Policy</a></li>
          <li><a href="/terms-and-conditions.html">Terms and Conditions</a></li>
          <li><a href="/support.html">Support</a></li>
          <li><a href="/delete-account.html">Delete Account</a></li>
        </ul>
      </section>
    </main>

    <footer class="site-footer">
      <p>&copy; <span id="year"></span> ColabGames</p>
      <div class="footer-links">
        <a href="/privacy-policy.html">Privacy</a>
        <a href="/terms-and-conditions.html">Terms</a>
        <a href="/support.html">Support</a>
        <a href="/delete-account.html">Delete Account</a>
      </div>
    </footer>

    <div
      id="auth-modal"
      class="auth-modal"
      <%= flash ? "" : "hidden" %>
    >
      <div
        class="auth-panel auth-panel-login"
        role="dialog"
        aria-modal="true"
        aria-label="Authentication"
        data-active-panel="<%= flash && flash.panel ? flash.panel : 'login' %>"
      >
        <button id="close-auth-btn" class="auth-close" type="button" aria-label="Close">X</button>

        <section id="auth-panel-login" class="auth-section" data-auth-panel="login">
          <h3>Login</h3>
          <form id="login-form" method="post" action="/login">
            <input
              id="auth-identifier"
              class="auth-input"
              type="text"
              name="identifier"
              maxlength="64"
              autocomplete="username"
              placeholder="Username or email"
              required
            />
            <input
              id="auth-password"
              class="auth-input"
              type="password"
              name="password"
              maxlength="72"
              autocomplete="current-password"
              placeholder="Password"
              required
            />

            <div class="auth-actions auth-actions-login">
              <button id="login-submit-btn" class="auth-action" type="submit">Login</button>
              <button id="show-register-btn" class="auth-action" type="button">Register</button>
            </div>
          </form>
          <button id="show-forgot-btn" class="auth-link auth-link-muted" type="button">
            Forgot password?
          </button>
        </section>

        <section id="auth-panel-register" class="auth-section" data-auth-panel="register" hidden>
          <h3>Register</h3>
          <form id="register-form" method="post" action="/register">
            <input
              class="auth-input"
              type="text"
              name="username"
              maxlength="24"
              autocomplete="username"
              placeholder="Username"
              required
            />
            <input
              class="auth-input"
              type="email"
              name="email"
              maxlength="120"
              autocomplete="email"
              placeholder="Email"
              required
            />
            <input
              class="auth-input"
              type="password"
              name="password"
              maxlength="72"
              minlength="8"
              autocomplete="new-password"
              placeholder="Password"
              required
            />
            <input
              class="auth-input"
              type="password"
              name="confirmPassword"
              maxlength="72"
              minlength="8"
              autocomplete="new-password"
              placeholder="Confirm password"
              required
            />
            <div class="auth-actions auth-actions-login">
              <button class="auth-action auth-login" type="submit">Create account</button>
              <button id="show-login-from-register-btn" class="auth-action" type="button">
                Back
              </button>
            </div>
          </form>
        </section>

        <section id="auth-panel-forgot" class="auth-section" data-auth-panel="forgot" hidden>
          <h3>Forgot Password</h3>
          <form id="forgot-form" method="post" action="/forgot-password">
            <input
              class="auth-input"
              type="text"
              name="identifier"
              maxlength="120"
              autocomplete="username"
              placeholder="Username or email"
              required
            />
            <div class="auth-actions auth-actions-login">
              <button class="auth-action auth-login" type="submit">Send reset link</button>
              <button id="show-login-from-forgot-btn" class="auth-action" type="button">
                Back
              </button>
            </div>
          </form>
          <p class="auth-note">
            If your account has an email, we will send a reset link valid for 1 hour.
          </p>
        </section>

        <p
          id="auth-error"
          class="auth-error <%= flash ? 'auth-error-' + flash.type : '' %>"
          role="alert"
        >
          <%= flash ? flash.message : "" %>
        </p>
      </div>
    </div>
  </body>
</html>

